                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="License Plate Damaged" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_LicensePlateDamaged" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Number of Nameplates" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="WMR_NumNameplates" Width="190" Value="0" Minimum="0" Maximum="20" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Adhesive Cleanup" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_AdhesiveCleanup" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 4: Equipment (empty per screenshot) -->
                            <StackPanel Grid.Column="3" Spacing="8" Margin="0,0,4,0">
                            </StackPanel>

                            <!-- Column 5: Add Ons -->
                            <StackPanel Grid.Column="4" Spacing="8">
                                <StackPanel>
                                    <TextBlock Text="Ceramic Coat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_CeramicCoat" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Price per Ceramic Coat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="WMR_CeramicCoatPrice" Width="190" Value="200" Minimum="0" Maximum="10000" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="PPF / Vinyl Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_PPFVinylWrap" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Price per PPF / Vinyl Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="WMR_PPFVinylWrapPrice" Width="190" Value="255" Minimum="0" Maximum="10000" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Pinstripes" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_Pinstripes" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Single"/>
                                        <ComboBoxItem Content="Dual"/>
                                        <ComboBoxItem Content="" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Edge Guard" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="WMR_EdgeGuard" Width="190" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ==================== INNER PANEL (Rows 433-439) ==================== -->
                    <StackPanel x:Name="InnerPanelPanel" Spacing="12" Visibility="Collapsed">
                        <Border Background="#3d3d3d" CornerRadius="4" Padding="12,8">
                            <TextBlock Text="Inner Panel" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <!-- Part Info Header Row -->
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,8">
                            <StackPanel Width="250">
                                <TextBlock Text="Inner Panel" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="IP_PartName" Width="240" PlaceholderText="e.g. RT and LT Wheelhouse" TextChanged="OnInputChanged"/>
                            </StackPanel>
                            <StackPanel Width="200">
                                <TextBlock Text="Repair Unit of Part" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <NumberBox x:Name="IP_RefinishUnits" Width="140" Value="9" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Labor" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Material" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Additional Parts" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Equipment" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Add Ons" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Main Grid with 5 columns -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Labor -->
                            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Size of Part" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_SizeOfPart" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Large" IsSelected="True"/>
                                        <ComboBoxItem Content="Small"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Trial Fit Labor Unit" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="IP_TrialFitLabor" Width="150" Value="0" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Backtape Jambs" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_BacktapeJambs" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 2: Material -->
                            <StackPanel Grid.Column="1" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Cavity Wax" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_CavityWax" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Seam Sealer" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_SeamSealer" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Chip Guard" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_ChipGuard" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Undercoat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="IP_Undercoat" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 3: Additional Parts (empty per screenshot) -->
                            <StackPanel Grid.Column="2" Spacing="8" Margin="0,0,4,0">
                            </StackPanel>

                            <!-- Column 4: Equipment (empty per screenshot) -->
                            <StackPanel Grid.Column="3" Spacing="8" Margin="0,0,4,0">
                            </StackPanel>

                            <!-- Column 5: Add Ons (empty per screenshot) -->
                            <StackPanel Grid.Column="4" Spacing="8">
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ==================== GLASS (Rows 483-487) ==================== -->
                    <StackPanel x:Name="GlassPanel" Spacing="12" Visibility="Collapsed">
                        <Border Background="#d4a574" CornerRadius="4" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Glass" FontSize="18" FontWeight="Bold" Foreground="#1e1e1e"/>
                                <TextBox x:Name="GL_PartName" Width="240" PlaceholderText="Lift gate glass" Background="Transparent" BorderThickness="0" Foreground="#333" FontSize="12" TextChanged="OnInputChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Column Headers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Labor" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Material" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Additional Parts" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Equipment" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Add Ons" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Main Grid with 5 columns -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Labor -->
                            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Size of Part" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_SizeOfPart" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Large" IsSelected="True"/>
                                        <ComboBoxItem Content="Small"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Body Primer" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_BodyPrimer" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Check Defrost" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_CheckDefrost" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Broken Glass Cleanup Labor Unit" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="GL_BrokenGlassCleanup" Width="150" Value="0" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 2: Material -->
                            <StackPanel Grid.Column="1" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Washer Fluid" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_WasherFluid" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 3: Additional Parts -->
                            <StackPanel Grid.Column="2" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Inspection Sticker" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_InspectionSticker" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="EZ Pass Velcro" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_EZPassVelcro" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 4: Equipment -->
                            <StackPanel Grid.Column="3" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Dash Cam" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_DashCam" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 5: Add Ons -->
                            <StackPanel Grid.Column="4" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Window Tint" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="GL_WindowTint" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Price per Window Tint" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="GL_WindowTintPrice" Width="170" Value="0" Minimum="0" Maximum="1000" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- RIGHT SIDE: Output panel with independent scroll -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8,0,0,0">
                <Border Background="#252526" CornerRadius="8" Padding="16" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Summary Header -->
                        <Border Background="#1e1e1e" CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="SummaryOps" Text="0" Foreground="#4ec9b0"/>
                                <TextBlock Text="Ops" Foreground="#4ec9b0"/>
                                <TextBlock Text="|" Foreground="#555"/>
                                <TextBlock Text="$" Foreground="#4ec9b0"/>
                                <TextBlock x:Name="SummaryPrice" Text="0.00" Foreground="#4ec9b0"/>
                                <TextBlock Text="|" Foreground="#555"/>
                                <TextBlock x:Name="SummaryLabor" Text="0" Foreground="#9cdcfe"/>
                                <TextBlock Text="Labor" Foreground="#9cdcfe"/>
                                <TextBlock Text="|" Foreground="#555"/>
                                <TextBlock x:Name="SummaryRefinish" Text="0.00" Foreground="#ce9178"/>
                                <TextBlock Text="Refinish" Foreground="#ce9178"/>
                            </StackPanel>
                        </Border>

                        <!-- Clip It Button -->
                        <Button x:Name="ClipItButton" Content="Clip it" HorizontalAlignment="Left" Margin="0,0,0,12"
                                Background="#0078d4" Foreground="White" Padding="16,8" Click="ClipItButton_Click"/>

                        <!-- Operations Table Header -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Operation" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="Description" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="Qty" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="3" Text="Price" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="4" Text="Labor" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="5" Text="Category" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                            <TextBlock Grid.Column="6" Text="Refinish" FontWeight="SemiBold" Foreground="#888" FontSize="11"/>
                        </Grid>

                        <!-- Operations List -->
                        <ListView x:Name="OperationsListView" MaxHeight="400" Background="Transparent"
                                  ItemsSource="{x:Bind ViewModel.CurrentOperations, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="55"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding OperationType}" FontSize="12" Foreground="White"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Quantity}" FontSize="12" Foreground="#ccc"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Price}" FontSize="12" Foreground="#4ec9b0"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Labor}" FontSize="12" Foreground="#9cdcfe"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Category}" FontSize="12" Foreground="#ccc"/>
                                        <TextBlock Grid.Column="6" Text="{Binding Refinish}" FontSize="12" Foreground="#ce9178"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- Export Panel -->
        <views:ExportPanel x:Name="ExportPanel" Grid.Row="2"/>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McStudDesktop.Views.PartOperationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:McStudDesktop.Views"
    mc:Ignorable="d"
    Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sub-Category Buttons -->
        <Border Grid.Row="0" Background="#252526" Padding="12,8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button x:Name="PlasticBlendBtn" Content="Plastic Part Blend" Tag="plasticblend" Click="SubCategoryButton_Click"
                            Background="#0078d4" Foreground="White" Padding="12,6"/>
                    <Button x:Name="PlasticRepairBtn" Content="Plastic Part Repair" Tag="plasticrepair" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="PlasticReplaceBtn" Content="Plastic Part Replace" Tag="plasticreplace" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="SmcBtn" Content="Carbon Fiber / SMC" Tag="smc" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="MetalBlendBtn" Content="Metal Part Blend" Tag="metalblend" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="MetalRepairBtn" Content="Metal Part Repair" Tag="metalrepair" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="BoltedMetalBtn" Content="Bolted Metal Replace" Tag="boltedmetal" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="WeldedMetalBtn" Content="Welded Metal Replace" Tag="weldedmetal" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="InnerPanelBtn" Content="Inner Panel" Tag="innerpanel" Click="SubCategoryButton_Click" Padding="12,6"/>
                    <Button x:Name="GlassBtn" Content="Glass" Tag="glass" Click="SubCategoryButton_Click" Padding="12,6"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" MinWidth="450"/>
                <ColumnDefinition Width="4*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Inputs -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <Grid>
                    <!-- ==================== PLASTIC PART BLEND (Rows 33-40) ==================== -->
                    <StackPanel x:Name="PlasticBlendPanel" Spacing="12" Visibility="Visible">
                        <Border Background="#2d5a27" CornerRadius="4" Padding="12,8">
                            <TextBlock Text="Plastic Part Blend" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <!-- Part Info Header Row -->
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,8">
                            <StackPanel Width="250">
                                <TextBlock Text="Part Name" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="PB_PartName" Width="240" PlaceholderText="e.g. Bumper" TextChanged="OnInputChanged"/>
                            </StackPanel>
                            <StackPanel Width="200">
                                <TextBlock Text="Exterior Refinish Unit of Part" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <NumberBox x:Name="PB_RefinishUnits" Width="140" Value="3" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Labor" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Material" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Additional Parts" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Equipment" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Add Ons" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Main Grid with 5 columns -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Labor -->
                            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="DE-NIB" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_A33" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="First Panel"/>
                                        <ComboBoxItem Content="Additional Panel" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Additional Panel" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_AdditionalPanel" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Part being Removed" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_A35" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes" IsSelected="True"/>
                                        <ComboBoxItem Content="No"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Trial Fit Labor Unit" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="PB_TrialFit" Width="150" Value="0" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 2: Material -->
                            <StackPanel Grid.Column="1" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Adhesion Promoter" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_B33" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes" IsSelected="True"/>
                                        <ComboBoxItem Content="No"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Flex Additive" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_B35" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 3: Additional Parts -->
                            <StackPanel Grid.Column="2" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Textured Portion on Part" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_C33" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="License Plate" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_C35" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Equipped"/>
                                        <ComboBoxItem Content="Not Equipped" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="License Plate Damaged" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_C37" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Number of Nameplates" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_Nameplates" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Adhesive Cleanup" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_C41" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 4: Equipment -->
                            <StackPanel Grid.Column="3" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Park Sensors" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_D33" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Number of Park Sensors" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="PB_D34" Width="170" Value="0" Minimum="0" Maximum="20" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Paint Park Sensor Brackets" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_D38" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Radar behind Painted Portion" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_D40" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 5: Add Ons -->
                            <StackPanel Grid.Column="4" Spacing="8">
                                <StackPanel>
                                    <TextBlock Text="Ceramic Coat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_E33" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Price per Ceramic Coat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="PB_CeramicPrice" Width="170" Value="0" Minimum="0" Maximum="1000" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="PPF / Vinyl Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PB_E34" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Price per PPF / Vinyl Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <NumberBox x:Name="PB_PPFPrice" Width="170" Value="0" Minimum="0" Maximum="1000" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ==================== PLASTIC PART REPAIR (Rows 83-91) ==================== -->
                    <StackPanel x:Name="PlasticRepairPanel" Spacing="12" Visibility="Collapsed">
                        <Border Background="#5a4227" CornerRadius="4" Padding="12,8">
                            <TextBlock Text="Plastic Part Repair" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <!-- Part Info Header Row -->
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,8">
                            <StackPanel Width="250">
                                <TextBlock Text="Part Name" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="PR_PartName" Width="240" PlaceholderText="e.g. Bumper" TextChanged="OnInputChanged"/>
                            </StackPanel>
                            <StackPanel Width="150">
                                <TextBlock Text="Repair Units" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <NumberBox x:Name="PR_RepairUnits" Width="140" Value="0.5" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" SmallChange="0.1" LargeChange="0.5" ValueChanged="OnInputChanged"/>
                            </StackPanel>
                            <StackPanel Width="200">
                                <TextBlock Text="Exterior Refinish Unit of Part" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <NumberBox x:Name="PR_RefinishUnits" Width="140" Value="3" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Labor" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Material" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Additional Parts" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Equipment" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Add Ons" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Main Grid with 5 columns -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Labor -->
                            <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="DE-NIB" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_A83" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="First Panel" IsSelected="True"/>
                                        <ComboBoxItem Content="Additional Panel"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Part being Removed" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_A85" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes" IsSelected="True"/>
                                        <ComboBoxItem Content="No"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 2: Material -->
                            <StackPanel Grid.Column="1" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Adhesion Promoter" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_B83" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes" IsSelected="True"/>
                                        <ComboBoxItem Content="No"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Flex Additive" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_B85" Width="150" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="First Large Part" IsSelected="True"/>
                                        <ComboBoxItem Content="Additional Large Part"/>
                                        <ComboBoxItem Content="Additional Small Part"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 3: Additional Parts -->
                            <StackPanel Grid.Column="2" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Textured Portion on Part" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_C83" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="License Plate" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_C85" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Equipped"/>
                                        <ComboBoxItem Content="Not Equipped" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="License Plate Damaged" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_C87" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Adhesive Cleanup" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_C91" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 4: Equipment -->
                            <StackPanel Grid.Column="3" Spacing="8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Park Sensors" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_D83" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Punch Holes"/>
                                        <ComboBoxItem Content="" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Number of Park Sensors" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_D84" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Install Brackets"/>
                                        <ComboBoxItem Content="" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Paint Park Sensor Brackets" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_D88" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Radar behind Painted Portion" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_D90" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Yes"/>
                                        <ComboBoxItem Content="No" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Column 5: Add Ons -->
                            <StackPanel Grid.Column="4" Spacing="8">
                                <StackPanel>
                                    <TextBlock Text="Ceramic Coat" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_E83" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Remove"/>
                                        <ComboBoxItem Content="" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="PPF / Vinyl Wrap" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PR_E84" Width="170" SelectionChanged="OnInputChanged">
                                        <ComboBoxItem Content="Apply"/>
                                        <ComboBoxItem Content="" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ==================== PLASTIC PART REPLACE (Rows 133-141) ==================== -->
                    <StackPanel x:Name="PlasticReplacePanel" Spacing="12" Visibility="Collapsed">
                        <Border Background="#275a5a" CornerRadius="4" Padding="12,8">
                            <TextBlock Text="Plastic Part Replace" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <!-- Part Info Header Row -->
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,8">
                            <StackPanel Width="250">
                                <TextBlock Text="Part Name" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="PRepl_PartName" Width="240" PlaceholderText="e.g. Bumper" TextChanged="OnInputChanged"/>
                            </StackPanel>
                            <StackPanel Width="200">
                                <TextBlock Text="Exterior Refinish Unit of Part" Foreground="#0078d4" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <NumberBox x:Name="PRepl_RefinishUnits" Width="140" Value="3" Minimum="0" Maximum="100" SpinButtonPlacementMode="Hidden" ValueChanged="OnInputChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Labor" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Material" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Additional Parts" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Equipment" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Background="#3d3d3d" Padding="8,4" CornerRadius="4" Margin="0,0,4,8">
                                <TextBlock Text="Add Ons" Foreground="#0078d4" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Main Grid with 5 columns -->

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McStudDesktop.Views.BodyOperationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:McStudDesktop.Views"
    mc:Ignorable="d"
    Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Section Buttons -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Export Panel -->
        </Grid.RowDefinitions>

        <!-- Section Buttons -->
        <Border Grid.Row="0" Background="#252526" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button x:Name="BodyOpsButton" Content="Body Operations" Tag="bodyops" Click="SectionButton_Click"
                        Background="#0078d4" Foreground="White" Padding="12,6"/>
                <Button x:Name="MeasurementsButton" Content="Measurements" Tag="measurements" Click="SectionButton_Click"
                        Background="#2d2d2d" Padding="12,6"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area - Split into two columns -->
        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="600"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Inputs -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel x:Name="InputsPanel" Spacing="12">
                    <!-- Header -->
                    <Border Background="#4a7c9b" CornerRadius="4" Padding="12,8">
                        <TextBlock x:Name="HeaderText" Text="Body Operations" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- Body Operations Section -->
                    <StackPanel x:Name="BodyOpsSection" Spacing="8">
                        <!-- Input Grid - 4 columns -->
                        <Border Background="#2d2d2d" CornerRadius="4" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Headers -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 1 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 2 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 3 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 4 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 5 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 6 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 7 -->
                                </Grid.RowDefinitions>

                                <!-- Column Headers -->
                                <Border Grid.Column="0" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Labor" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="1" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Material" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="2" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Tooling" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="3" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Equipment" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Row 1 -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Collision Damage Access" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="CollisionDamageAccess" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Structural Adhesive" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="StructuralAdhesive" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Rivet Gun" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="RivetGun" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Welding" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="Welding" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 2 -->
                                <StackPanel Grid.Column="0" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Body Plugs" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="BodyPlugs" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Cure Time" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="CureTime" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Nutsert Gun" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="NutsertGun" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Number of Welders" Foreground="#64b4ff" FontSize="10"/>
                                    <NumberBox x:Name="NumberOfWelders" Width="100" Value="1" Minimum="0" Maximum="10" SpinButtonPlacementMode="Hidden" ValueChanged="OnNumberChanged"/>
                                </StackPanel>

                                <!-- Row 3 -->
                                <StackPanel Grid.Column="0" Grid.Row="3" Margin="4">
                                    <TextBlock Text="Remove Factory E-Coat" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="RemoveFactoryECoat" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="3" Margin="4">
                                    <TextBlock Text="Spark Paper" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="SparkPaper" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="3" Margin="4">
                                    <TextBlock Text="Crack Dye Test" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="CrackDyeTest" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="3" Margin="4">
                                    <TextBlock Text="Plastic Welder" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="PlasticWelder" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 4 -->
                                <StackPanel Grid.Column="1" Grid.Row="4" Margin="4">
                                    <TextBlock Text="Undercoat" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="Undercoat" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="4" Margin="4">
                                    <TextBlock Text="Tap and Die Set" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="TapAndDieSet" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="4" Margin="4">
                                    <TextBlock Text="Puller" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="Puller" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 5 -->
                                <StackPanel Grid.Column="1" Grid.Row="5" Margin="4">
                                    <TextBlock Text="# of Sound Deadener Pads" Foreground="#64b4ff" FontSize="10"/>
                                    <NumberBox x:Name="SoundDeadenerPads" Width="100" Value="0" Minimum="0" Maximum="20" SpinButtonPlacementMode="Hidden" ValueChanged="OnNumberChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="5" Margin="4">
                                    <TextBlock Text="Weld Pull Tabs" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="WeldPullTabs" Width="130" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Measurements Section (hidden by default) -->
                    <StackPanel x:Name="MeasurementsSection" Spacing="8" Visibility="Collapsed">
                        <Border Background="#2d2d2d" CornerRadius="4" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Headers -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 1 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 2 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 3 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 4 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 5 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 6 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 7 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Row 8 -->
                                </Grid.RowDefinitions>

                                <!-- Column Headers -->
                                <Border Grid.Column="0" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Labor" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <Border Grid.Column="1" Grid.Row="0" Background="#3c5a6e" Padding="8,6" Margin="1">
                                    <TextBlock Text="Equipment" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Labor Column -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Measure Gap Dimensions" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="MeasureGapDimensions" Width="150" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Tram Gauge" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="TramGauge" Width="150" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Equipment Column -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4">
                                    <TextBlock Text="Frame Bench" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="FrameBench" Width="180" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="2" Margin="4">
                                    <TextBlock Text="Measure" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="MeasureType" Width="180" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content=""/>
                                        <ComboBoxItem Content="Pre"/>
                                        <ComboBoxItem Content="In-Process"/>
                                        <ComboBoxItem Content="Post"/>
                                        <ComboBoxItem Content="Pre, In-Process, Post"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="3" Margin="4">
                                    <TextBlock Text="Pull Labor Unit" Foreground="#64b4ff" FontSize="10"/>
                                    <NumberBox x:Name="PullLaborUnit" Width="100" Value="3" Minimum="0" Maximum="50" SpinButtonPlacementMode="Hidden" ValueChanged="OnNumberChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="4" Margin="4">
                                    <TextBlock Text="Securing Method" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="SecuringMethod" Width="180" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                        <ComboBoxItem Content=""/>
                                        <ComboBoxItem Content="Pinch Welds"/>
                                        <ComboBoxItem Content="Truck Clamps"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="5" Margin="4">
                                    <TextBlock Text="Jig Setup" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="JigSetup" Width="180" SelectionChanged="OnInputChanged" SelectedIndex="0">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="6" Margin="4">
                                    <TextBlock Text="Extra Fixtures" Foreground="#64b4ff" FontSize="10"/>
                                    <ComboBox x:Name="ExtraFixtures" Width="180" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT SIDE: Operations List -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="8,0,0,0">
                <StackPanel x:Name="OperationsPanel" Spacing="8">
                    <!-- Summary Header -->
                    <Border Background="#2d2d2d" CornerRadius="4" Padding="12,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <HyperlinkButton Content="Back to top" FontSize="11"/>
                            </StackPanel>
                            <StackPanel x:Name="SummaryPanel" Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <TextBlock x:Name="SummaryOps" Text="0 Ops" Foreground="#64b4ff" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryPrice" Text="$ 0" Foreground="#64c864" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryLabor" Text="0 Labor" Foreground="#64b4ff" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryRefinish" Text="0 Refinish" Foreground="#ffb464" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Clip it button -->
                    <Button x:Name="ClipItButton" Content="Clip it" HorizontalAlignment="Left" Padding="12,6" Background="#3c3c3c" Foreground="White"/>

                    <!-- Operations Header Row -->
                    <Border Background="#3c3c3c" CornerRadius="4" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <!-- Operation -->
                                <ColumnDefinition Width="*"/>
                                <!-- Description -->
                                <ColumnDefinition Width="60"/>
                                <!-- Quantity -->
                                <ColumnDefinition Width="60"/>
                                <!-- Price -->
                                <ColumnDefinition Width="60"/>
                                <!-- Labor -->
                                <ColumnDefinition Width="70"/>
                                <!-- Category -->
                                <ColumnDefinition Width="60"/>
                                <!-- Refinish -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Operation" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Description" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Quantity" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Price" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Labor" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Category" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="Refinish" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Operations List Container -->
                    <StackPanel x:Name="OperationsList" Spacing="2">
                        <TextBlock x:Name="NoOperationsText"
                                   Text="Select options to generate operations."
                                   Foreground="#8c8c8c" FontSize="14" TextWrapping="Wrap" Margin="0,20,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Export Panel -->
        <views:ExportPanel x:Name="ExportPanel" Grid.Row="2"/>
    </Grid>
</Page>

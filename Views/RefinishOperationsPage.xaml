<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McStudDesktop.Views.RefinishOperationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:McStudDesktop.Views"
    mc:Ignorable="d"
    Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <Grid Grid.Row="0" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="600"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Inputs -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel x:Name="InputsPanel" Spacing="12">
                    <!-- Header -->
                    <Border Background="#d4a574" CornerRadius="4" Padding="12,8">
                        <TextBlock Text="Refinish Operations" FontSize="16" FontWeight="Bold" Foreground="#1e1e1e"/>
                    </Border>

                    <!-- Input Grid matching Excel layout -->
                    <Border Background="#2d2d2d" CornerRadius="4" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/> <!-- Paint -->
                                <ColumnDefinition Width="180"/> <!-- Additional Colors -->
                                <ColumnDefinition Width="120"/> <!-- Tooling -->
                                <ColumnDefinition Width="160"/> <!-- Additional -->
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Headers -->
                                <RowDefinition Height="Auto"/> <!-- Row 1 -->
                                <RowDefinition Height="Auto"/> <!-- Row 2 -->
                                <RowDefinition Height="Auto"/> <!-- Row 3 -->
                                <RowDefinition Height="Auto"/> <!-- Row 4 -->
                                <RowDefinition Height="Auto"/> <!-- Row 5 -->
                                <RowDefinition Height="Auto"/> <!-- Row 6 -->
                                <RowDefinition Height="Auto"/> <!-- Row 7 -->
                                <RowDefinition Height="Auto"/> <!-- Row 8 -->
                                <RowDefinition Height="Auto"/> <!-- Row 9 -->
                            </Grid.RowDefinitions>

                            <!-- Column Headers -->
                            <Border Grid.Column="0" Grid.Row="0" Background="#d4a574" Padding="8,6" Margin="1">
                                <TextBlock Text="Paint" Foreground="#1e1e1e" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="0" Background="#d4a574" Padding="8,6" Margin="1">
                                <TextBlock Text="Additional Colors" Foreground="#1e1e1e" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="2" Grid.Row="0" Background="#d4a574" Padding="8,6" Margin="1">
                                <TextBlock Text="Tooling" Foreground="#1e1e1e" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Column="3" Grid.Row="0" Background="#d4a574" Padding="8,6" Margin="1">
                                <TextBlock Text="Additional" Foreground="#1e1e1e" FontSize="11" FontWeight="SemiBold"/>
                            </Border>

                            <!-- Paint Column -->
                            <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="9" Background="#252526" Padding="8" Margin="1">
                                <StackPanel Spacing="8">
                                    <!-- Paint Stage -->
                                    <StackPanel>
                                        <TextBlock Text="Paint Stage" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="PaintStage" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="2-Stage"/>
                                            <ComboBoxItem Content="3-Stage"/>
                                            <ComboBoxItem Content="4-Stage"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Additional Radar Formula -->
                                    <StackPanel>
                                        <TextBlock Text="Additional Radar Formula" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="AdditionalRadarFormula" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Four Stage Refinish -->
                                    <StackPanel>
                                        <TextBlock Text="Four Stage Refinish" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FourStageRefinish" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="2">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Input Exterior Refinish -->
                                    <StackPanel>
                                        <TextBlock Text="Input Exterior Refinish" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBlock Text="Unit of all Parts" Foreground="#888" FontSize="9" Margin="0,0,0,2"/>
                                        <TextBlock Text="Being Painted - Below" Foreground="#888" FontSize="9" Margin="0,0,0,4"/>
                                        <NumberBox x:Name="ExteriorRefinishUnit" Width="140" Value="3" Minimum="0" Maximum="100"
                                                   SpinButtonPlacementMode="Hidden" SmallChange="0.1" LargeChange="1"
                                                   ValueChanged="OnNumberChanged"/>
                                    </StackPanel>

                                    <!-- Additional number inputs -->
                                    <NumberBox x:Name="ExteriorRefinishUnit2" Width="140" Value="2" Minimum="0" Maximum="100"
                                               SpinButtonPlacementMode="Hidden" SmallChange="0.1" LargeChange="1"
                                               ValueChanged="OnNumberChanged"/>
                                    <NumberBox x:Name="ExteriorRefinishUnit3" Width="140" Value="2.6" Minimum="0" Maximum="100"
                                               SpinButtonPlacementMode="Hidden" SmallChange="0.1" LargeChange="1"
                                               ValueChanged="OnNumberChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- Additional Colors Column -->
                            <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="9" Background="#252526" Padding="8" Margin="1">
                                <StackPanel Spacing="8">
                                    <!-- Second Color -->
                                    <StackPanel>
                                        <TextBlock Text="Second Color" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="SecondColor" Width="160" PlaceholderText="Enter color" TextChanged="OnTextChanged"/>
                                    </StackPanel>

                                    <!-- Second Color Paint Stage -->
                                    <StackPanel>
                                        <TextBlock Text="Second Color Paint Stage" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="SecondColorPaintStage" Width="160" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="2-Stage"/>
                                            <ComboBoxItem Content="3-Stage"/>
                                            <ComboBoxItem Content="4-Stage"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Third Color -->
                                    <StackPanel>
                                        <TextBlock Text="Third Color" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ThirdColor" Width="160" PlaceholderText="Enter color" TextChanged="OnTextChanged"/>
                                    </StackPanel>

                                    <!-- Third Color Paint Stage -->
                                    <StackPanel>
                                        <TextBlock Text="Third Color Paint Stage" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="ThirdColorPaintStage" Width="160" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="2-Stage"/>
                                            <ComboBoxItem Content="3-Stage"/>
                                            <ComboBoxItem Content="4-Stage"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Fourth Color -->
                                    <StackPanel>
                                        <TextBlock Text="Fourth Color" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="FourthColor" Width="160" PlaceholderText="Enter color" TextChanged="OnTextChanged"/>
                                    </StackPanel>

                                    <!-- Fourth Color Paint Stage -->
                                    <StackPanel>
                                        <TextBlock Text="Fourth Color Paint Stage" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FourthColorPaintStage" Width="160" SelectionChanged="OnInputChanged" SelectedIndex="2">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="2-Stage"/>
                                            <ComboBoxItem Content="3-Stage"/>
                                            <ComboBoxItem Content="4-Stage"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Fifth Color -->
                                    <StackPanel>
                                        <TextBlock Text="Fifth Color" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="FifthColor" Width="160" PlaceholderText="Enter color" TextChanged="OnTextChanged"/>
                                    </StackPanel>

                                    <!-- Fifth Color Paint Stage -->
                                    <StackPanel>
                                        <TextBlock Text="Fifth Color Paint Stage" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="FifthColorPaintStage" Width="160" SelectionChanged="OnInputChanged" SelectedIndex="2">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="2-Stage"/>
                                            <ComboBoxItem Content="3-Stage"/>
                                            <ComboBoxItem Content="4-Stage"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Matte Clear Price -->
                                    <StackPanel>
                                        <TextBlock Text="Matte Clear Price" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <NumberBox x:Name="MatteClearPrice" Width="160" Value="0" Minimum="0" Maximum="10000"
                                                   SpinButtonPlacementMode="Hidden" SmallChange="1" LargeChange="10"
                                                   ValueChanged="OnNumberChanged"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Tooling Column -->
                            <Border Grid.Column="2" Grid.Row="1" Grid.RowSpan="9" Background="#252526" Padding="8" Margin="1">
                                <StackPanel Spacing="8">
                                    <!-- Static Gun -->
                                    <StackPanel>
                                        <TextBlock Text="Static Gun" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="StaticGun" Width="100" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Additional Column -->
                            <Border Grid.Column="3" Grid.Row="1" Grid.RowSpan="9" Background="#252526" Padding="8" Margin="1">
                                <StackPanel Spacing="8">
                                    <!-- Touch Up Painted Bolts -->
                                    <StackPanel>
                                        <TextBlock Text="Touch Up Painted Bolts" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="TouchUpPaintedBolts" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="2">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Special Color Tint -->
                                    <StackPanel>
                                        <TextBlock Text="Special Color Tint" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="SpecialColorTint" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Monitor Time -->
                                    <StackPanel>
                                        <TextBlock Text="Monitor Time" Foreground="#64b4ff" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MonitorTime" Width="140" SelectionChanged="OnInputChanged" SelectedIndex="1">
                                            <ComboBoxItem Content=""/>
                                            <ComboBoxItem Content="No"/>
                                            <ComboBoxItem Content="Yes"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT SIDE: Operations List -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="8,0,0,0">
                <StackPanel x:Name="OperationsPanel" Spacing="8">
                    <!-- Summary Header -->
                    <Border Background="#2d2d2d" CornerRadius="4" Padding="12,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <HyperlinkButton Content="Back to top" FontSize="11"/>
                            </StackPanel>
                            <StackPanel x:Name="SummaryPanel" Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <TextBlock x:Name="SummaryOps" Text="0 Ops" Foreground="#64b4ff" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryPrice" Text="$ 0" Foreground="#64c864" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryLabor" Text="0 Labor" Foreground="#64b4ff" FontSize="12"/>
                                <TextBlock Text="|" Foreground="#555" FontSize="12"/>
                                <TextBlock x:Name="SummaryRefinish" Text="0 Refinish" Foreground="#ffb464" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Clip it button -->
                    <Button x:Name="ClipItButton" Content="Clip it" HorizontalAlignment="Left" Padding="12,6" Background="#3c3c3c" Foreground="White"/>

                    <!-- Operations Header Row -->
                    <Border Background="#3c3c3c" CornerRadius="4" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Operation" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Description" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Quantity" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Price" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Labor" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Category" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="Refinish" Foreground="#64b4ff" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Operations List Container -->
                    <StackPanel x:Name="OperationsList" Spacing="2">
                        <TextBlock x:Name="NoOperationsText"
                                   Text="Select options to generate operations."
                                   Foreground="#8c8c8c" FontSize="14" TextWrapping="Wrap" Margin="0,20,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Export Panel -->
        <views:ExportPanel x:Name="ExportPanel" Grid.Row="1"/>
    </Grid>
</Page>

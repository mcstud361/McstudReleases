        "Attach alignment heads to wheels",
        "Perform compensation/calibration",
        "Measure current alignment angles",
        "Compare to OEM specifications",
        "Adjust camber (if adjustable)",
        "Adjust caster (if adjustable)",
        "Adjust toe (front and rear)",
        "Verify thrust angle",
        "Print alignment report"
      ],
      "timeGuideline": "1.0 - 1.5 hours",
      "equipment": [
        "4-wheel alignment machine",
        "Alignment heads/sensors",
        "Turn plates",
        "OEM specifications"
      ],
      "prerequisites": [
        "Suspension components properly installed",
        "Proper tire pressure",
        "No worn/damaged suspension parts"
      ],
      "triggers": [
        "Suspension component R&R",
        "Steering component R&R",
        "Subframe R&R",
        "Structural repair affecting suspension points"

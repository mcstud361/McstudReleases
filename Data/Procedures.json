        "Calibration targets",
        "Measuring tape/laser",
        "Level surface"
      ],
      "prerequisites": [
        "Wheel alignment completed",
        "All related repairs completed",
        "Clean sensors/cameras"
      ],
      "systemsCovered": [
        "Forward collision warning",
        "Automatic emergency braking",
        "Lane departure warning",
        "Lane keep assist",
        "Adaptive cruise control"

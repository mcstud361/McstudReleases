    {
      "id": "proc-prescan",
      "name": "Pre-Repair Diagnostic Scan",
      "category": "Diagnostics",
      "operation": "NOT INCLUDED",
      "pPageRef": "G9",
      "description": "Performing a diagnostic scan on the vehicle before repairs begin to identify pre-existing and collision-related DTCs.",
      "steps": [
        "Connect scan tool to vehicle OBD-II port",
        "Connect battery support (if required)",
        "Turn ignition to ON/RUN position",
        "Perform all-module scan",
        "Document all DTCs present",
        "Note freeze frame data",
        "Print/save scan report"
      ],
      "timeGuideline": "0.5 - 1.0 hour depending on vehicle complexity",
      "oilRequirement": "Required by most OEMs for any collision repair",
      "equipment": [
        "OEM or compatible diagnostic scan tool",
        "Battery support device",
        "Printer (optional)"
      ],
      "notes": "Always document scan results before clearing any codes.",
      "tags": ["scan", "diagnostic", "pre-repair", "DTC"]
    },
    {
      "id": "proc-postscan",
      "name": "Post-Repair Diagnostic Scan",
      "category": "Diagnostics",
      "operation": "NOT INCLUDED",
      "pPageRef": "G9",
      "description": "Performing a diagnostic scan after repairs to verify no new DTCs and all systems functioning properly.",
      "steps": [
        "Complete all repairs",
        "Connect scan tool to vehicle",
        "Connect battery support (if required)",
        "Perform all-module scan",
        "Clear any repair-related DTCs (if appropriate)",
        "Verify no new DTCs present",
        "Road test and re-scan",
        "Print/save final scan report"
      ],
      "timeGuideline": "0.5 - 1.0 hour",
      "equipment": [
        "OEM or compatible diagnostic scan tool",
        "Battery support device"
      ],
      "notes": "Some DTCs require drive cycle to clear. Final scan should show clean results.",
      "tags": ["scan", "diagnostic", "post-repair", "verification"]
    },
    {

      "formula": {
        "type": "conditional",
        "condition": "weldedPanel == true",
        "value": 0.2
      }
    },
    "cavityWax": {
      "name": "Cavity Wax",
      "category": "body",
      "formula": {
        "type": "conditional",
        "condition": "weldedPanel == true || hasClosedCavities == true",
        "value": 0.3
      }
    },
    "prepNewPart": {
      "name": "Prep New/Unprimed Part",
      "category": "body",
      "formula": {
        "type": "conditional",
        "condition": "isReplacement == true",
        "value": 0.4
      }
    },
    "transferEmblems": {
      "name": "Transfer Emblems/Moldings",
      "category": "body",
      "formula": {
        "type": "perItem",
        "valuePerItem": 0.1
      }
    },
    "wetDrySand": {
      "name": "Wet/Dry Sand & Buff",
      "category": "refinish",
      "formula": {
        "type": "percentage",
        "baseOn": "refinishHours",
        "percentage": 0.10,
        "min": 0.2,
        "max": 0.8,
        "condition": "refinishHours >= 1.5"
      }
    }

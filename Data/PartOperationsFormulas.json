        "formula": {
          "type": "percentage",
          "baseOn": "refinishHours",
          "percentage": 0.10,
          "min": 0.2,
          "max": 0.5
        }
      }
    ]
  },

  "calculationPresets": {
    "plasticPartBlend": {
      "name": "Plastic Part Blend",
      "description": "Blending adjacent plastic panel",
      "operations": ["de-nib", "adhesion-promoter", "flex-additive", "mask-overspray"],
      "conditions": {
        "requiresRefinishHours": true,
        "requiresPartRemoval": "optional"
      }
    },
    "plasticPartRepair": {
      "name": "Plastic Part Repair",
      "description": "Repairing damage on plastic part",
      "operations": ["de-nib", "adhesion-promoter", "flex-additive", "prime-block", "mask-overspray"],
      "conditions": {
        "requiresRefinishHours": true,
        "requiresBodyHours": true
      }
    },
    "plasticPartReplace": {
      "name": "Plastic Part Replace",
      "description": "Replacing plastic part",
      "operations": ["de-nib", "adhesion-promoter", "flex-additive", "trial-fit", "prep-new-part", "mask-overspray", "cover-car-basic"],
      "conditions": {
        "requiresRefinishHours": true,
        "checkLicensePlate": true,
        "checkParkSensors": true,
        "checkRadar": true
      }
    },
    "metalPartBlend": {
      "name": "Metal Part Blend",
      "description": "Blending adjacent metal panel",
      "operations": ["de-nib", "mask-overspray"],
      "conditions": {
        "requiresRefinishHours": true
      }
    },
    "metalPartRepair": {
      "name": "Metal Part Repair",
      "description": "Repairing damage on metal part",
      "operations": ["de-nib", "prime-block", "corrosion-protection", "mask-overspray"],
      "conditions": {
        "requiresRefinishHours": true,
        "requiresBodyHours": true
      }
    },
    "boltedMetalReplace": {
      "name": "Bolted Metal Part Replace",
      "description": "Replacing bolted-on metal part (fender, hood, etc.)",
      "operations": ["de-nib", "trial-fit", "prep-new-part", "transfer-emblems", "corrosion-protection", "mask-overspray", "cover-car-basic"],
      "conditions": {
        "requiresRefinishHours": true,
        "checkEmblemTransfer": true
      }
    },
    "weldedMetalReplace": {
      "name": "Welded Metal Part Replace",
      "description": "Replacing welded structural panel (quarter, rocker, etc.)",
      "operations": ["remove-ecoat", "weld-through-primer", "seam-sealer", "corrosion-protection", "cavity-wax", "de-nib", "mask-overspray", "cover-car-full"],
      "conditions": {
        "requiresRefinishHours": true,
        "requiresBodyHours": true,
        "structuralWork": true,
        "checkWelding": true,
        "checkAdhesive": true
      }
    }
  },

  "commonOperationDefaults": {
    "primeBlock": {
      "name": "Prime & Block Repair Area",
      "category": "body",
      "formula": {
        "type": "percentage",
        "baseOn": "bodyHours",
        "percentage": 0.15,
        "min": 0.3,
        "max": 1.0
      }
    },
    "corrosionProtection": {
      "name": "Corrosion Protection",
      "category": "body",
      "formula": {
        "type": "conditional",
        "condition": "bodyHours >= 1.0 || weldedPanel == true",
        "value": 0.3
      }
    },
    "seamSealer": {
      "name": "Seam Sealer",
      "category": "body",
      "formula": {
        "type": "conditional",
        "condition": "weldedPanel == true",
        "value": 0.4
      }
    },
    "weldThroughPrimer": {
      "name": "Weld-Through Primer",

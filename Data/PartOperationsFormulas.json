{
  "version": "1.0",
  "source": "McStud Estimating Tool Excel - master.xlsx",
  "lastUpdated": "2025-02-05",
  "description": "Real operation formulas and calculations extracted from the McStud Estimating Tool",

  "partTypes": {
    "plasticPart": {
      "name": "Plastic Part",
      "aliases": ["bumper", "fascia", "valance", "spoiler", "air dam", "ground effects", "plastic cover", "rocker cover", "wheel lip molding", "fender flare"],
      "requiresAdhesionPromoter": true,
      "requiresFlexAdditive": true
    },
    "metalPartBolted": {
      "name": "Bolted Metal Part",
      "aliases": ["fender", "hood", "trunk lid", "deck lid", "liftgate", "tailgate", "tail gate", "door shell", "mirror", "door", "front door", "rear door"],
      "requiresAdhesionPromoter": false,
      "requiresFlexAdditive": false
    },
    "wheelTire": {
      "name": "Wheel/Tire",
      "aliases": ["wheel", "rim", "tire", "alloy wheel", "steel wheel", "spare tire", "wheel cover", "hub cap", "hubcap", "lug nuts", "tpms", "tpms sensor"],
      "requiresTPMS": true,
      "requiresBalancing": true
    },
    "metalPartWelded": {
      "name": "Welded Metal Part",
      "aliases": ["quarter panel", "quarter", "rocker", "pillar", "a-pillar", "b-pillar", "c-pillar", "roof", "floor pan", "wheelhouse", "inner fender", "apron", "rail", "frame rail"],
      "requiresCorrosionProtection": true,
      "requiresWeldThroughPrimer": true,
      "requiresSeamSealer": true
    },
    "carbonFiber": {
      "name": "Carbon Fiber / SMC / Composite",
      "aliases": ["carbon fiber", "carbon fibre", "smc", "composite", "fiberglass"],
      "requiresSpecialRepair": true
    },
    "glass": {
      "name": "Glass",
      "aliases": ["windshield", "back glass", "rear glass", "door glass", "quarter glass", "vent glass"],
      "requiresSpecialHandling": true
    }
  },

  "operationCategories": {
    "labor": {
      "name": "Labor Operations",
      "operations": [
        {
          "id": "de-nib",
          "name": "DE-NIB",
          "description": "Remove nibs and imperfections from painted surface",
          "category": "refinish",
          "appliesTo": ["blend", "repair", "replace"],
          "formula": {
            "type": "conditional",
            "condition": "refinishHours >= 0.5",
            "value": 0.2,
            "notes": "Flat rate when refinishing"
          }
        },
        {
          "id": "trial-fit",
          "name": "Trial Fit",
          "description": "Test fit replacement part before paint",
          "category": "body",
          "appliesTo": ["replace"],
          "formula": {
            "type": "input",
            "defaultValue": 0.3,
            "notes": "User inputs actual labor units based on part"
          }
        },
        {
          "id": "part-removed",
          "name": "Part Being Removed for Refinish",
          "description": "When part is removed from vehicle for painting",
          "category": "body",
          "appliesTo": ["blend", "refinish"],
          "formula": {
            "type": "conditional",
            "condition": "partRemoved == true",
            "value": 0.0,
            "notes": "Just a flag indicating removal"
          }
        }
      ]
    },

    "material": {
      "name": "Material Operations",
      "operations": [
        {
          "id": "adhesion-promoter",
          "name": "Adhesion Promoter",
          "description": "Chemical prep for flexible/plastic parts",
          "category": "refinish",
          "appliesTo": ["blend", "repair", "replace"],
          "partTypes": ["plasticPart"],
          "formula": {
            "type": "percentage",
            "baseOn": "refinishHours",
            "percentage": 0.10,
            "min": 0.2,
            "max": 0.5,
            "notes": "10% of refinish hours, min 0.2, max 0.5"
          }
        },
        {
          "id": "flex-additive",
          "name": "Flex Additive",
          "description": "Flexible additive for paint on plastic parts",
          "category": "refinish",
          "appliesTo": ["blend", "repair", "replace"],
          "partTypes": ["plasticPart"],
          "formula": {
            "type": "conditional",
            "condition": "isFirstLargePart && isPlasticPart",
            "value": 0.2,
            "notes": "0.2 for first large plastic part being painted"
          }
        }
      ]
    },

    "additionalParts": {
      "name": "Additional Parts Operations",
      "operations": [
        {
          "id": "textured-portion",
          "name": "Textured Portion on Part",
          "description": "Part has textured/grained finish areas",
          "category": "refinish",
          "appliesTo": ["replace"],
          "formula": {
            "type": "conditional",
            "condition": "hasTexturedPortion == true",
            "value": 0.3,
            "notes": "Additional time for textured areas"
          }
        },
        {
          "id": "license-plate-ri",
          "name": "R&I License Plate",
          "description": "Remove and install license plate",
          "category": "body",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "conditional",
            "condition": "hasLicensePlate == true",
            "value": 0.1,
            "notes": "When license plate is mounted on part"
          }
        },
        {
          "id": "license-plate-drill",
          "name": "Drill for License Plate",
          "description": "Drill holes for license plate on new part",
          "category": "body",
          "appliesTo": ["replace"],
          "formula": {
            "type": "conditional",
            "condition": "licensePlateDamaged == true || newPartNoDrills == true",
            "value": 0.2,
            "notes": "When drilling required on new part"
          }
        },
        {
          "id": "nameplate-transfer",
          "name": "Transfer Nameplates/Emblems",
          "description": "Transfer nameplates and emblems to new part",
          "category": "body",
          "appliesTo": ["replace"],
          "formula": {
            "type": "perItem",
            "valuePerItem": 0.1,
            "notes": "0.1 per nameplate/emblem"
          }
        },
        {
          "id": "adhesive-cleanup",
          "name": "Adhesive Cleanup",
          "description": "Clean adhesive residue from emblem/molding removal",
          "category": "body",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "conditional",
            "condition": "adhesiveCleanup == true",
            "value": 0.2,
            "notes": "When cleaning old adhesive"
          }
        }
      ]
    },

    "equipment": {
      "name": "Equipment Operations",
      "operations": [
        {
          "id": "park-sensors",
          "name": "R&I Park Sensors",
          "description": "Remove and install parking sensors",
          "category": "body",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "perItem",
            "valuePerItem": 0.15,
            "notes": "0.15 per sensor"
          }
        },
        {
          "id": "paint-sensor-brackets",
          "name": "Paint Park Sensor Brackets",
          "description": "Paint sensor bracket mounting areas",
          "category": "refinish",
          "appliesTo": ["replace"],
          "formula": {
            "type": "conditional",
            "condition": "paintSensorBrackets == true",
            "value": 0.2,
            "notes": "When painting sensor mounting areas"
          }
        },
        {
          "id": "radar-painted-portion",
          "name": "Radar Behind Painted Portion",
          "description": "Special coating for radar-transparent painted area",
          "category": "refinish",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "conditional",
            "condition": "hasRadarBehindPaint == true",
            "value": 0.3,
            "notes": "Special paint/clear requirements for radar"
          }
        }
      ]
    },

    "addOns": {
      "name": "Add-On Operations",
      "operations": [
        {
          "id": "ceramic-coat",
          "name": "Ceramic Coat",
          "description": "Apply ceramic coating to painted surface",
          "category": "detail",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "priced",
            "defaultPrice": 100,
            "laborHours": 0.5,
            "notes": "Price varies by customer preference"
          }
        },
        {
          "id": "ppf-vinyl",
          "name": "PPF / Vinyl Wrap",
          "description": "Install paint protection film or vinyl wrap",
          "category": "detail",
          "appliesTo": ["replace", "refinish"],
          "formula": {
            "type": "priced",
            "defaultPrice": 150,
            "laborHours": 1.0,
            "notes": "Install protective film"
          }
        }
      ]
    }
  },

